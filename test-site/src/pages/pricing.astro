---
import Layout from '../layouts/Layout.astro'
---
<Layout title="Pricing" variant="control — /pricing">
  <main style="max-width:900px;margin:0 auto;padding:80px 40px;text-align:center">

    <h1 style="font-size:48px;font-weight:800;letter-spacing:-1.5px;margin-bottom:12px">Simple pricing</h1>
    <p style="color:#6b7280;font-size:17px;margin-bottom:56px">Start free. Upgrade when you need more.</p>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px">
      <!-- Hobby -->
      <div style="border:1px solid #e5e7eb;border-radius:20px;padding:28px;text-align:left">
        <p style="font-size:13px;font-weight:600;color:#6b7280;margin-bottom:12px">HOBBY</p>
        <p style="font-size:40px;font-weight:800;letter-spacing:-1px">$0</p>
        <p style="color:#9ca3af;font-size:13px;margin-bottom:24px">/month forever</p>
        <a href="/thank-you" style="display:block;text-align:center;border:1px solid #e5e7eb;border-radius:10px;padding:10px;font-size:14px;font-weight:600;color:#374151;margin-bottom:24px">Get started</a>
        <ul style="list-style:none;font-size:14px;color:#4b5563;display:flex;flex-direction:column;gap:10px">
          <li>✓ 10,000 events/mo</li>
          <li>✓ 1 site</li>
          <li>✓ 30-day retention</li>
        </ul>
      </div>

      <!-- Pro (highlighted) -->
      <div style="border:2px solid #111;border-radius:20px;padding:28px;text-align:left;position:relative">
        <div style="position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:#111;color:#fff;font-size:11px;font-weight:700;padding:4px 12px;border-radius:999px">MOST POPULAR</div>
        <p style="font-size:13px;font-weight:600;color:#6b7280;margin-bottom:12px">PRO</p>
        <p style="font-size:40px;font-weight:800;letter-spacing:-1px">$29</p>
        <p style="color:#9ca3af;font-size:13px;margin-bottom:24px">/month</p>
        <a href="/thank-you" style="display:block;text-align:center;background:#111;color:#fff;border-radius:10px;padding:10px;font-size:14px;font-weight:600;margin-bottom:24px">Start free trial</a>
        <ul style="list-style:none;font-size:14px;color:#4b5563;display:flex;flex-direction:column;gap:10px">
          <li>✓ 1M events/mo</li>
          <li>✓ 10 sites</li>
          <li>✓ 1-year retention</li>
          <li>✓ Custom dashboards</li>
        </ul>
      </div>

      <!-- Enterprise -->
      <div style="border:1px solid #e5e7eb;border-radius:20px;padding:28px;text-align:left">
        <p style="font-size:13px;font-weight:600;color:#6b7280;margin-bottom:12px">ENTERPRISE</p>
        <p style="font-size:40px;font-weight:800;letter-spacing:-1px">$99</p>
        <p style="color:#9ca3af;font-size:13px;margin-bottom:24px">/month</p>
        <a href="/thank-you" style="display:block;text-align:center;border:1px solid #e5e7eb;border-radius:10px;padding:10px;font-size:14px;font-weight:600;color:#374151;margin-bottom:24px">Contact sales</a>
        <ul style="list-style:none;font-size:14px;color:#4b5563;display:flex;flex-direction:column;gap:10px">
          <li>✓ Unlimited events</li>
          <li>✓ Unlimited sites</li>
          <li>✓ SSO / SAML</li>
          <li>✓ SLA + priority support</li>
        </ul>
      </div>
    </div>

  </main>
</Layout>
