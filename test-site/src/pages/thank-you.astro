---
import Layout from '../layouts/Layout.astro'
---
<Layout title="Thank you" variant="conversion page">
  <main style="max-width:600px;margin:0 auto;padding:120px 40px;text-align:center">

    <div style="width:64px;height:64px;background:#dcfce7;border-radius:20px;display:flex;align-items:center;justify-content:center;margin:0 auto 24px;font-size:32px">
      ✓
    </div>

    <h1 style="font-size:36px;font-weight:800;letter-spacing:-1px;margin-bottom:12px">You're in!</h1>
    <p style="color:#6b7280;font-size:17px;line-height:1.6;margin-bottom:40px">
      Thanks for signing up. Check your inbox for your magic link.
    </p>

    <a href="/" style="display:inline-block;background:#111;color:#fff;padding:12px 28px;border-radius:12px;font-weight:600;font-size:15px">
      ← Back to homepage
    </a>

    <p style="color:#d1d5db;font-size:12px;margin-top:48px">
      This is the <strong>conversion page</strong> — Splitr records a conversion event when a user reaches this URL.
    </p>
  </main>
</Layout>
