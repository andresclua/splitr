---
interface Props {
  title: string
  variant?: string
}
const { title, variant = 'control' } = Astro.props
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Beacon</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0 }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #fff; color: #111 }
    a { color: inherit; text-decoration: none }
  </style>
</head>
<body>
  <!-- Debug badge — makes it obvious which variant you're seeing -->
  <div style="position:fixed;bottom:16px;right:16px;z-index:999;background:#111;color:#fff;font-size:11px;font-weight:600;padding:6px 12px;border-radius:999px;letter-spacing:.5px;opacity:.85">
    Splitr · {variant}
  </div>

  <nav style="border-bottom:1px solid #e5e7eb;padding:0 40px;height:60px;display:flex;align-items:center;justify-content:space-between;max-width:1200px;margin:0 auto;width:100%">
    <span style="font-weight:700;font-size:18px">Beacon</span>
    <div style="display:flex;gap:24px;font-size:14px;color:#6b7280">
      <a href="/pricing" style="hover:color:#111">Pricing</a>
      <a href="/thank-you" style="background:#111;color:#fff;padding:8px 18px;border-radius:8px;font-weight:600">Get started</a>
    </div>
  </nav>

  <slot />
</body>
</html>
