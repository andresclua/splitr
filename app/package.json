{
  "name": "app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxt/content": "^3.1.0",
    "@nuxtjs/supabase": "^1.4.6",
    "@supabase/supabase-js": "^2.47.0",
    "@tailwindcss/typography": "^0.5.19",
    "better-sqlite3": "^12.8.0",
    "nuxt": "^4.0.0",
    "stripe": "^17.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^3.15.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "happy-dom": "^15.11.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "**/*.{ts,vue}": [
      "vitest related --run"
    ],
    "**/*.{ts,vue,json,md}": [
      "prettier --write"
    ]
  }
}
